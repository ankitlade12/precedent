# --- Slack app credentials -------------------------------------------------
# Create an app from manifest.json (api.slack.com/apps → Create New App → From a
# manifest), install it to your developer sandbox, then copy the tokens here.
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token   # needs connections:write (Socket Mode)
SLACK_SIGNING_SECRET=your-signing-secret

# --- Real-Time Search API --------------------------------------------------
# Semantic recall requires a Slack AI-enabled workspace. A user token is only
# needed to search private channels / DMs (search:read.private, etc.).
SLACK_USER_TOKEN=xoxp-optional-user-token

# --- Precedent's own MCP server (other agents dial this) -------------------
MCP_PORT=3010
MCP_PATH=/mcp
MCP_BEARER_TOKEN=change-me

# --- LLM proposer (optional) -----------------------------------------------
# The built-in HeuristicDetector needs no key; set this to plug in the LLM
# detector for richer extraction.
ANTHROPIC_API_KEY=
