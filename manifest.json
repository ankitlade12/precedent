{
  "display_information": {
    "name": "Precedent",
    "description": "The decision memory your team and its agents can trust.",
    "background_color": "#1a1a2e"
  },
  "features": {
    "bot_user": {
      "display_name": "precedent",
      "always_online": true
    },
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": false
    },
    "slash_commands": [
      {
        "command": "/precedent",
        "description": "Ask what the team decided, with the receipts",
        "usage_hint": "why <topic>",
        "should_escape": false
      }
    ],
    "shortcuts": [
      {
        "name": "Log this decision",
        "type": "message",
        "callback_id": "log_decision",
        "description": "Capture this message or thread as a decision"
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "chat:write.public",
        "app_mentions:read",
        "channels:read",
        "channels:history",
        "channels:join",
        "groups:read",
        "groups:history",
        "commands",
        "mcp:connect",
        "search:read.public"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.channels",
        "message.groups",
        "app_mention",
        "app_home_opened"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
